-- ======================================================================
-- Test: EXCEPT with C collation
-- ======================================================================
-- All uppercase names (< 'a' under C) except DEF
SELECT name FROM t_c_collation WHERE name < 'a'
EXCEPT
SELECT name FROM t_c_collation WHERE name = 'DEF'
ORDER BY name;
 name 
------
 ABC
